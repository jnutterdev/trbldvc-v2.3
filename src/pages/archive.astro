---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allReviews = await getCollection('reviews');

// Sort by published date descending
const reviews = [...allReviews].sort((a, b) => {
  const da = a.data.published_date ? new Date(a.data.published_date).getTime() : 0;
  const db = b.data.published_date ? new Date(b.data.published_date).getTime() : 0;
  return db - da;
});
---
<BaseLayout title="TERRIBLEDevice — Archive" activeNav="archive">
  <header class="page-header">
    <div class="page-eyebrow">&#x25A0;&nbsp; All reviews</div>
    <h1 class="page-title">Data <em>Archive</em></h1>
  </header>

  <div class="filters-bar">
    <div class="filter-group">
      <span class="filter-label">Medium</span>
      <div class="filter-pills">
        <button class="filter-pill active" data-filter="medium" data-value="all">All</button>
        <button class="filter-pill" data-filter="medium" data-value="novel">Novel</button>
        <button class="filter-pill" data-filter="medium" data-value="film">Film</button>
        <button class="filter-pill" data-filter="medium" data-value="anime">Anime</button>
        <button class="filter-pill" data-filter="medium" data-value="tv">TV</button>
        <button class="filter-pill" data-filter="medium" data-value="comic">Comic</button>
        <button class="filter-pill" data-filter="medium" data-value="music">Music</button>
      </div>
    </div>
    <div class="filter-divider"></div>
    <div class="filter-group">
      <span class="filter-label">Era</span>
      <div class="filter-pills">
        <button class="filter-pill active" data-filter="era" data-value="all">All</button>
        <button class="filter-pill" data-filter="era" data-value="80s">80s</button>
        <button class="filter-pill" data-filter="era" data-value="90s">90s</button>
        <button class="filter-pill" data-filter="era" data-value="00s">00s</button>
      </div>
    </div>
    <button class="filter-reset" id="resetBtn">&#x25A0; Reset</button>
  </div>

  <div class="tag-filter-bar" id="tagFilterBar" style="display: none">
    <span class="tag-filter-label">&#x25A0; tag:</span>
    <span class="tag-filter-value" id="tagFilterValue"></span>
    <button class="tag-filter-clear" id="tagFilterClear" aria-label="Clear tag filter">&#x2715;</button>
  </div>

  <div class="reviews-grid" id="reviewsGrid">
    {reviews.map(r => {
      const displayCreator = r.data.medium === 'music'
        ? [r.data.artist, r.data.label].filter(Boolean).join(' \u2014 ')
        : r.data.creator;

      return (
        <a
          href={`/reviews/${r.slug}`}
          class="review-card rc-all"
          data-medium={r.data.medium}
          data-era={r.data.era}
          data-tags={r.data.tags?.join(',') ?? ''}
        >
          <p class="panel-meta"><span>&#x25A0;</span> {r.data.medium} &mdash; {r.data.year}</p>
          <h3 class="review-title">{r.data.title}</h3>
          {displayCreator && <p class="review-creator">{displayCreator}</p>}
          {r.data.blurb && <p class="review-blurb">{r.data.blurb}</p>}
          <div class="review-footer">
            <span class="review-score">{r.data.score}</span>
            <span class="review-type">{r.data.medium}</span>
          </div>
        </a>
      );
    })}

    <div class="empty-state" id="emptyState">
      <div class="empty-title">No signal found</div>
      <div class="empty-sub">&#x25A0; Try a different filter combination</div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  const cards = document.querySelectorAll('.review-card');
  const emptyState = document.getElementById('emptyState');
  const resetBtn = document.getElementById('resetBtn');
  const tagFilterBar = document.getElementById('tagFilterBar');
  const tagFilterValue = document.getElementById('tagFilterValue');
  const tagFilterClear = document.getElementById('tagFilterClear');

  let activeMedium = 'all';
  let activeEra = 'all';
  let activeTag = '';

  const cornerClasses = ['rc-tl', 'rc-tr', 'rc-br', 'rc-bl', 'rc-all'];
  const cornerPattern = ['rc-tl', 'rc-all', 'rc-br', 'rc-bl', 'rc-all', 'rc-tr'];

  function applyCorners(visibleCards) {
    visibleCards.forEach((card, i) => {
      cornerClasses.forEach(c => card.classList.remove(c));
      card.classList.add(cornerPattern[i % cornerPattern.length]);
    });
  }

  function syncUrl() {
    const url = new URL(window.location);
    activeMedium === 'all' ? url.searchParams.delete('medium') : url.searchParams.set('medium', activeMedium);
    activeEra === 'all' ? url.searchParams.delete('era') : url.searchParams.set('era', activeEra);
    activeTag ? url.searchParams.set('tag', activeTag) : url.searchParams.delete('tag');
    window.history.replaceState({}, '', url);
  }

  function filterCards() {
    const visible = [];
    cards.forEach(card => {
      const mediumMatch = activeMedium === 'all' || card.dataset.medium === activeMedium;
      const eraMatch = activeEra === 'all' || card.dataset.era === activeEra;
      const tagMatch = !activeTag || (card.dataset.tags || '').split(',').includes(activeTag);
      if (mediumMatch && eraMatch && tagMatch) {
        card.classList.remove('hidden');
        visible.push(card);
      } else {
        card.classList.add('hidden');
      }
    });
    applyCorners(visible);
    emptyState.classList.toggle('visible', visible.length === 0);
  }

  function setTagFilter(tag) {
    activeTag = tag;
    if (tag) {
      tagFilterValue.textContent = tag;
      tagFilterBar.style.display = 'flex';
    } else {
      tagFilterBar.style.display = 'none';
      tagFilterValue.textContent = '';
    }
  }

  document.querySelectorAll('.filter-pill[data-filter="medium"]').forEach(pill => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('.filter-pill[data-filter="medium"]').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      activeMedium = pill.dataset.value;
      filterCards();
      syncUrl();
    });
  });

  document.querySelectorAll('.filter-pill[data-filter="era"]').forEach(pill => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('.filter-pill[data-filter="era"]').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      activeEra = pill.dataset.value;
      filterCards();
      syncUrl();
    });
  });

  resetBtn.addEventListener('click', () => {
    document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
    document.querySelector('[data-filter="medium"][data-value="all"]').classList.add('active');
    document.querySelector('[data-filter="era"][data-value="all"]').classList.add('active');
    activeMedium = 'all';
    activeEra = 'all';
    setTagFilter('');
    filterCards();
    syncUrl();
  });

  tagFilterClear.addEventListener('click', () => {
    setTagFilter('');
    filterCards();
    syncUrl();
  });

  // Read all filters from URL on load
  const params = new URLSearchParams(window.location.search);
  const mediumParam = params.get('medium');
  const eraParam = params.get('era');
  const tagParam = params.get('tag');

  if (mediumParam) {
    const pill = document.querySelector(`[data-filter="medium"][data-value="${mediumParam}"]`);
    if (pill) {
      document.querySelectorAll('.filter-pill[data-filter="medium"]').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      activeMedium = mediumParam;
    }
  }

  if (eraParam) {
    const pill = document.querySelector(`[data-filter="era"][data-value="${eraParam}"]`);
    if (pill) {
      document.querySelectorAll('.filter-pill[data-filter="era"]').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      activeEra = eraParam;
    }
  }

  if (tagParam) setTagFilter(tagParam);

  filterCards();
</script>

<style>
  .tag-filter-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    margin-bottom: 20px;
    border: 1px solid var(--pink-dim);
    border-radius: var(--r);
    background: rgba(115, 37, 78, 0.08);
  }

  .tag-filter-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--tan-dim);
    text-transform: uppercase;
  }

  .tag-filter-value {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--pink);
    text-transform: uppercase;
    padding: 2px 10px;
    border: 1px solid var(--pink-dim);
    border-radius: 999px;
  }

  .tag-filter-clear {
    background: transparent;
    border: none;
    color: var(--tan-dim);
    font-size: 14px;
    cursor: pointer;
    margin-left: 4px;
    padding: 0 4px;
    line-height: 1;
    transition: color 0.2s;
  }

  .tag-filter-clear:hover {
    color: var(--pink);
  }

  .filters-bar {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0 var(--r) var(--r) var(--r);
    padding: 1rem 1.4rem;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .filter-group {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .filter-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    color: var(--tan-dim);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .filter-pills {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .filter-pill {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    padding: 4px 12px;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--tan-dim);
    text-transform: uppercase;
    cursor: pointer;
    background: transparent;
    transition: border-color 0.2s, color 0.2s;
    user-select: none;
  }

  .filter-pill:hover {
    border-color: var(--pink-dim);
    color: var(--tan);
  }

  .filter-pill.active {
    border-color: var(--pink);
    color: var(--pink);
  }

  .filter-divider {
    width: 1px;
    height: 20px;
    background: var(--border);
    flex-shrink: 0;
  }

  .filter-reset {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--tan-dim);
    text-transform: uppercase;
    cursor: pointer;
    background: transparent;
    border: none;
    margin-left: auto;
    padding: 0;
    transition: color 0.2s;
  }

  .filter-reset:hover {
    color: var(--pink);
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .review-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    padding: 1.3rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    cursor: pointer;
  }

  .review-card:hover {
    border-color: var(--pink);
    box-shadow:
      0 0 0 1px var(--pink-dim),
      inset 0 0 24px rgba(255, 92, 141, 0.05);
    animation: glitch 0.35s linear;
  }

  .review-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px, transparent 3px,
      rgba(0, 0, 0, 0.18) 3px, rgba(0, 0, 0, 0.18) 4px
    );
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .review-card:hover::before {
    opacity: 1;
  }

  .review-card.hidden {
    display: none;
  }

  .review-title {
    font-family: var(--head);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #fff;
    text-transform: uppercase;
    margin-bottom: 2px;
    line-height: 1.05;
  }

  .review-creator {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--tan-dim);
    letter-spacing: 0.14em;
    margin-bottom: 10px;
  }

  .review-blurb {
    font-size: 13px;
    line-height: 1.6;
    color: var(--tan-dim);
    margin-bottom: 14px;
    flex: 1;
  }

  .review-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 10px;
    border-top: 1px solid var(--border);
  }

  .review-score {
    font-family: var(--head);
    font-size: 28px;
    font-weight: 700;
    color: var(--pink);
    line-height: 1;
  }

  .empty-state {
    grid-column: 1 / 4;
    padding: 60px 20px;
    text-align: center;
    display: none;
  }

  .empty-state.visible {
    display: block;
  }

  .empty-title {
    font-family: var(--head);
    font-size: 32px;
    font-weight: 700;
    color: var(--tan-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 8px;
  }

  .empty-sub {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--pink-dim);
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .page-title {
      font-size: 52px;
    }

    .reviews-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .empty-state {
      grid-column: 1 / 3;
    }
  }

  @media (max-width: 640px) {
    .page-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }

    .page-title {
      font-size: 44px;
    }

    .filters-bar {
      gap: 12px;
      padding: 0.8rem 1rem;
    }

    .filter-divider {
      display: none;
    }

    .reviews-grid {
      grid-template-columns: 1fr;
    }

    .empty-state {
      grid-column: 1;
    }

    .review-card {
      border-radius: var(--r) !important;
    }
  }
</style>
