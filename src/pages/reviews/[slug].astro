---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const reviews = await getCollection('reviews', ({ data }) => !data.draft);
  return reviews.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await entry.render();

// Word count from raw markdown body
const wordCount = entry.body
  ? entry.body.trim().split(/\s+/).filter(Boolean).length
  : 0;

// Published date formatting
const pubDate = data.published_date
  ? new Date(data.published_date).toLocaleDateString('en-US', {
      month: '2-digit',
      year: 'numeric',
    })
  : '';

// Resolve related reviews
const allReviews = await getCollection('reviews');
const relatedReviews = data.related
  ? data.related
      .map(slug => allReviews.find(r => r.slug === slug))
      .filter(Boolean)
  : [];

const isMusic = data.medium === 'music';
const relatedCorners = ['rc-tl', 'rc-all', 'rc-br'];

const listenIcons: Record<string, string> = {
  bandcamp: 'fa-bandcamp',
  soundcloud: 'fa-soundcloud',
  youtube: 'fa-youtube',
  ampwall: 'fa-headphones',
};
---
<BaseLayout title={`TERRIBLEDevice — ${data.title}`} activeNav="archive">
  <header class="post-header">
    <div class="breadcrumb">
      <a href="/">Reviews</a>
      <span>/</span>
      <a href={`/archive?medium=${data.medium}`}>{data.medium.charAt(0).toUpperCase() + data.medium.slice(1)}</a>
      <span>/</span>
      {data.title}
    </div>
    <div class="post-eyebrow">
      &#x25A0;&nbsp;
      {isMusic ? `Music \u2014 ${data.year}` : data.medium.charAt(0).toUpperCase() + data.medium.slice(1)}
    </div>
    <h1 class="post-title">
      {data.title}
      {isMusic && data.artist && <em>{data.artist}</em>}
    </h1>
    <div class="post-byline">
      {isMusic
        ? <>
            {data.label && <span>{data.label}</span>}
            {pubDate && <span>Published {pubDate}</span>}
            {data.genre_tags?.map(t => <span class="genre-tag">{t}</span>)}
          </>
        : <>
            {data.creator && <span>By {data.creator}</span>}
            {pubDate && <span>Published {pubDate}</span>}
            {wordCount > 0 && <span>{wordCount.toLocaleString()} words</span>}
          </>
      }
    </div>
  </header>

  <div class="post-wrap">
    <!-- Score block -->
    <div class="score-block">
      <div class="score-big">{data.score}</div>
      <div class="score-meta">
        {data.verdict && <div class="score-verdict">{data.verdict}</div>}
        {data.summary && <p class="score-summary">{data.summary}</p>}
        {isMusic && data.listen_platform && data.listen_url && (
          <a href={data.listen_url} class="listen-link" target="_blank" rel="noopener">
            <i class={`fa-brands ${listenIcons[data.listen_platform] ?? 'fa-headphones'}`}></i>
            Listen on {data.listen_platform.charAt(0).toUpperCase() + data.listen_platform.slice(1)}
          </a>
        )}
      </div>
      {data.score_bars && data.score_bars.length > 0 && (
        <div class="score-bars">
          {data.score_bars.map(bar => (
            <div class="bar-row">
              <div class="bar-label-row">
                <span class="bar-key">{bar.label}</span>
                <span class="bar-key">{bar.value}%</span>
              </div>
              <div class="bar-track">
                <div class="bar-fill" style={`width: ${bar.value}%`}></div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Review body -->
    <div class="post-body">
      <Content />
    </div>

    <!-- Tags -->
    {data.tags && data.tags.length > 0 && (
      <div class="tags-section">
        <p class="tags-label"><span>&#x25A0;</span> tagged</p>
        <div class="tags-list">
          {data.tags.map(tag => (
            <a href={`/archive?tag=${encodeURIComponent(tag)}`} class="tag">{tag}</a>
          ))}
        </div>
      </div>
    )}
  </div>

  <!-- Related reviews -->
  {relatedReviews.length > 0 && (
    <div class="related-section">
      <div class="section-header">
        <span>&#x25A0;</span> Related reviews
      </div>
      <div class="related-grid">
        {relatedReviews.map((r, i) => {
          if (!r) return null;
          const displayCreator = r.data.medium === 'music'
            ? [r.data.artist, r.data.label].filter(Boolean).join(' \u2014 ')
            : r.data.creator;
          return (
            <a href={`/reviews/${r.slug}`} class={`review-card ${relatedCorners[i] ?? 'rc-all'}`}>
              <p class="panel-meta"><span>&#x25A0;</span> {r.data.medium} &mdash; {r.data.year}</p>
              <h3 class="review-title">{r.data.title}</h3>
              {displayCreator && <p class="review-author">{displayCreator}</p>}
              {r.data.blurb && <p class="review-blurb">{r.data.blurb}</p>}
              <div class="review-footer">
                <span class="review-score">{r.data.score}</span>
                <span class="review-type">{r.data.medium}</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  )}
</BaseLayout>

<style>
  /* ── Post header ── */
  .breadcrumb {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--tan-dim);
    text-transform: uppercase;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .breadcrumb a {
    color: var(--tan-dim);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--pink);
  }

  .breadcrumb span {
    color: var(--pink-dim);
  }

  .post-header {
    margin-bottom: 40px;
  }

  .post-eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--pink);
    text-transform: uppercase;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .post-eyebrow::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--pink-dim);
    opacity: 0.4;
  }

  .post-title {
    font-family: var(--head);
    font-size: 80px;
    font-weight: 700;
    line-height: 0.88;
    letter-spacing: -0.01em;
    color: #fff;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .post-title em {
    color: var(--pink);
    font-style: normal;
    display: block;
  }

  .post-byline {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--tan-dim);
    text-transform: uppercase;
    margin-top: 16px;
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .genre-tag {
    color: var(--steel-lt);
    border: 1px solid var(--steel);
    padding: 2px 8px;
    border-radius: 999px;
  }

  /* ── Post wrap ── */
  .post-wrap {
    max-width: 680px;
    margin: 0 auto;
  }

  /* ── Score block ── */
  .score-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 0 var(--r) var(--r) var(--r);
    padding: 1.4rem;
    margin-bottom: 40px;
    display: flex;
    align-items: center;
    gap: 32px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .score-block:hover {
    border-color: var(--pink);
    box-shadow: 0 0 0 1px var(--pink-dim), inset 0 0 24px rgba(255, 92, 141, 0.05);
    animation: glitch 0.35s linear;
  }

  .score-block::before {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px, transparent 3px,
      rgba(0, 0, 0, 0.18) 3px, rgba(0, 0, 0, 0.18) 4px
    );
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .score-block:hover::before {
    opacity: 1;
  }

  .score-big {
    font-family: var(--head);
    font-size: 96px;
    font-weight: 700;
    color: var(--pink);
    line-height: 1;
    flex-shrink: 0;
  }

  .score-meta {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .score-verdict {
    font-family: var(--head);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: #fff;
    text-transform: uppercase;
  }

  .score-summary {
    font-size: 14px;
    color: var(--tan-dim);
    line-height: 1.6;
  }

  .listen-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    padding: 6px 14px;
    border: 1px solid var(--pink-dim);
    border-radius: 999px;
    color: var(--pink);
    text-decoration: none;
    text-transform: uppercase;
    transition: border-color 0.2s, background 0.2s;
    align-self: flex-start;
  }

  .listen-link:hover {
    background: rgba(255, 92, 141, 0.08);
    border-color: var(--pink);
  }

  .score-bars {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 180px;
  }

  .bar-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .bar-label-row {
    display: flex;
    justify-content: space-between;
  }

  .bar-key {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--tan-dim);
    text-transform: uppercase;
  }

  /* ── Review body ── */
  .post-body {
    margin-bottom: 40px;
  }

  .post-body :global(p) {
    font-size: 16px;
    line-height: 1.8;
    color: var(--tan-dim);
    margin-bottom: 1.2em;
  }

  .post-body :global(p:first-child::first-letter) {
    font-family: var(--head);
    font-size: 64px;
    font-weight: 700;
    color: var(--pink);
    float: left;
    line-height: 0.75;
    margin-right: 8px;
    margin-top: 8px;
  }

  .post-body :global(strong) {
    color: var(--tan);
    font-weight: 500;
  }

  .post-body :global(blockquote) {
    border-left: 2px solid var(--pink-dim);
    padding: 4px 0 4px 20px;
    margin: 1.6em 0;
  }

  .post-body :global(blockquote p) {
    font-family: var(--head);
    font-size: 22px;
    font-weight: 600;
    color: var(--tan);
    line-height: 1.3;
    letter-spacing: 0.02em;
    margin: 0;
  }

  .post-body :global(blockquote p::first-letter) {
    all: unset;
  }

  /* ── Tags ── */
  .tags-section {
    padding-top: 24px;
    margin-bottom: 64px;
  }

  .tags-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--tan-dim);
    text-transform: uppercase;
    margin-bottom: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .tags-label::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--tan-dim);
    opacity: 0.4;
  }

  .tags-label span {
    color: var(--pink);
    margin-right: 6px;
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* ── Related reviews ── */
  .related-section {
    max-width: 1060px;
    margin: 0 auto;
  }

  .section-header {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--tan-dim);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-header span {
    color: var(--pink);
  }

  .section-header::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .review-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    padding: 1.2rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
    display: block;
  }

  .review-card:hover {
    border-color: var(--pink);
    box-shadow: 0 0 0 1px var(--pink-dim), inset 0 0 24px rgba(255, 92, 141, 0.05);
    animation: glitch 0.35s linear;
  }

  .review-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px, transparent 3px,
      rgba(0, 0, 0, 0.18) 3px, rgba(0, 0, 0, 0.18) 4px
    );
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .review-card:hover::before {
    opacity: 1;
  }

  .review-title {
    font-family: var(--head);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #fff;
    text-transform: uppercase;
    margin-bottom: 2px;
    line-height: 1.1;
  }

  .review-author {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--tan-dim);
    letter-spacing: 0.14em;
    margin-bottom: 10px;
  }

  .review-blurb {
    font-size: 13px;
    line-height: 1.6;
    color: var(--tan-dim);
    margin-bottom: 14px;
  }

  .review-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .review-score {
    font-family: var(--head);
    font-size: 24px;
    font-weight: 700;
    color: var(--pink);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .post-title {
      font-size: 60px;
    }

    .score-big {
      font-size: 72px;
    }

    .related-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: 48px;
    }

    .post-byline {
      flex-direction: column;
      gap: 4px;
    }

    .score-block {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .score-big {
      font-size: 64px;
    }

    .score-bars {
      min-width: unset;
      width: 100%;
    }

    .post-body :global(p:first-child::first-letter) {
      font-size: 44px;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .review-card {
      border-radius: var(--r) !important;
    }
  }
</style>
